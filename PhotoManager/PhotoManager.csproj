<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\app.ico" />
  </ItemGroup>

  <Target Name="GenerateAppIcon" BeforeTargets="BeforeBuild">
    <Exec Command="dotnet run --project &quot;$(MSBuildThisFileDirectory)..\PhotoManager.IconGen\PhotoManager.IconGen.csproj&quot; -- &quot;$(MSBuildThisFileDirectory)Resources\app.ico&quot;"
          Condition="!Exists('$(MSBuildThisFileDirectory)Resources\app.ico')" />
  </Target>

</Project>